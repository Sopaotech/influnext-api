{
  "name": "influnext-api",
  "version": "1.0.0",
  "main": "src/server.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:web": "cd web && npm run dev",
    "dev:api": "cd src && npx ts-node server.ts",
    "build": "npx prisma generate && tsc -p tsconfig.json",
    "build:api": "tsc -p tsconfig.json",
    "build:web": "cd web && npm run build",
    "start": "node dist/server.js",
    "prisma:generate": "npx prisma generate",
    "deploy:prod": "npm run build && npm run build:web",
    "seed": "npx ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.10.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.76.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.20",
    "@types/qrcode": "^1.5.6",
    "prisma": "^5.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}

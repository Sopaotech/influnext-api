{
  "name": "influnext-api",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node prisma/setup-provider.js && npx ts-node src/scripts/kill-port.ts && ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:web": "cd web && npm run dev",
    "dev:api": "node prisma/setup-provider.js && cd src && npx ts-node server.ts",
    "build": "node prisma/setup-provider.js && prisma generate && tsc",
    "build:web": "cd web && npm run build",
    "start": "node dist/server.js",
    "prisma:generate": "node prisma/setup-provider.js && prisma generate",
    "deploy:prod": "npm run build && npm run build:web",
    "seed": "npx ts-node prisma/seed.ts",
    "db:reset-prod": "npx ts-node prisma/reset-production.ts",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.3",
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.76.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "firebase-admin": "^14.1.0",
    "googleapis": "^134.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^13.4.0",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "stripe": "^22.1.0",
    "typescript": "^5.3.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.20",
    "@types/qrcode": "^1.5.6",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}

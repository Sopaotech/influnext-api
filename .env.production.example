# ==========================================
# INFLUNEXT - PRODUCTION ENVIRONMENT VARIABLES (OFFICIAL DOMAIN)
# ==========================================

# ─── Configurações Básicas ───────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Domínios e CORS (Multi-Domínio) ─────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://influnext.com.br
NEXT_PUBLIC_API_URL=https://api.influnext.com.br/v1
ALLOWED_ORIGINS=https://influnext.com.br,https://www.influnext.com.br
FRONTEND_URL=https://influnext.com.br

# Domínio base para o Cookie JWT (Essencial para Auth funcionar em subdomínios)
NEXT_PUBLIC_COOKIE_DOMAIN=.influnext.com.br

# ─── Banco de Dados (PostgreSQL) ─────────────────────────────────────────
# URL do banco de produção (Railway, Supabase, Neon)
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# ─── Segurança (JWT & Escrow) ────────────────────────────────────────────
JWT_SECRET="GERAR_NO_TERMINAL_COM_CRYPTO_RANDOMBYTES"

# ─── Redis (BullMQ / Filas) ──────────────────────────────────────────────
REDIS_URL="rediss://default:password@host:port"

# ─── APIs Externas (IA & Uploads) ────────────────────────────────────────
GEMINI_API_KEY="sua_chave_gemini_1.5_flash"
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# ─── Gateway de Pagamento (Pagar.me / Stripe) ────────────────────────────
PAYMENT_GATEWAY_API_KEY="sk_live_sua_chave_aqui"
PAYMENT_WEBHOOK_SECRET="whsec_seu_webhook_secret"

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Nota: SQLite não suporta Enums. Usaremos String com validação em nível de aplicação.
// As roles serão: "INFLUENCER", "COMPANY", "ADMIN"
// Os status serão: "DRAFT", "PENDING_PAYMENT", "IN_PROGRESS", "UNDER_REVIEW", "COMPLETED", "DISPUTE"

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  role             String // "INFLUENCER" | "COMPANY" | "ADMIN"
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String? // AES-256-GCM encrypted
  profileImageUrl  String?
  createdAt        DateTime @default(now())

  // Preferências de Aparência
  theme       String @default("light") // "dark" | "light" | "system"
  accentColor String @default("#a855f7")

  // SaaS e Assinaturas
  onboardingCompleted    Boolean   @default(false)
  subscriptionStatus     String    @default("TRIAL") // "TRIAL" | "ACTIVE" | "INACTIVE"
  subscriptionTier       String    @default("FREE") // "FREE" | "PRO" | "MASTER" | "ENTERPRISE"
  isFeatured             Boolean   @default(false)
  featuredUntil          DateTime?
  credits                Int       @default(0)
  trialEndsAt            DateTime?
  stripeCustomerId       String?   @unique // ID do cliente na Stripe
  stripeConnectAccountId String?   @unique // ID da conta Stripe Connect (Express) do influenciador

  subscriptions  Subscription[]
  influencer     InfluencerProfile?
  company        CompanyProfile?
  notifications  Notification[]
  supportTickets SupportTicket[]
}

model Plan {
  id            String         @id @default(uuid())
  name          String // "Pro Influencer", "Enterprise Brand"
  price         Float
  interval      String // "month", "year"
  externalId    String? // ID do plano no Pagar.me/Stripe
  active        Boolean        @default(true)
  subscriptions Subscription[]
}

model Subscription {
  id                String   @id @default(uuid())
  userId            String
  planId            String
  externalId        String?  @unique // ID da assinatura no Gateway
  status            String // "active", "past_due", "canceled"
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id])
  plan      Plan     @relation(fields: [planId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InfluencerProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id])
  handle          String  @unique
  profileImageUrl String?
  verifiedMetrics Boolean @default(false)
  niche           String?
  careerObjective String? // "SALES", "FAME", "NETWORKING", etc.
  aiInterview     String? // JSON stringified with dreams, goals, follower targets, etc.
  influScore      Int     @default(0)
  scoreClass      String  @default("BRONZE")

  // Gamificação: Missões Diárias
  dailyMission      String?
  missionCompleted  Boolean   @default(false)
  lastMissionUpdate DateTime?
  lastLoginAt       DateTime  @default(now())

  // Hiper-Localismo
  city  String?
  state String?
  bio   String?

  insights String? // SQLite não suporta Json, usaremos String (JSON stringified)
  topPosts String? // SQLite não suporta Json, usaremos String (JSON stringified)

  // Endereço de Recebidos
  shippingAddress String?
  poBox           String?
  shareAddress    Boolean    @default(false)
  recebidos       Recebido[]

  platforms      SocialPlatform[]
  tasks          Task[]
  metricsHistory MetricSnapshot[]
  contracts      Contract[]
  aiAnalyses     AIAnalysis[]
  trendVault     TrendReference[]
  rateCards      RateCard[]
}

model TrendReference {
  id           String   @id @default(uuid())
  influencerId String
  title        String
  videoUrl     String
  thumbnail    String?
  niche        String
  createdAt    DateTime @default(now())
  expiresAt    DateTime // Data de criação + 20 dias

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])
}

model CompanyProfile {
  id                   String              @id @default(uuid())
  userId               String              @unique
  user                 User                @relation(fields: [userId], references: [id])
  companyName          String
  taxId                String              @unique
  city                 String?
  state                String?
  segment              String?
  employeeCount        String?
  campaignBudget       String?
  salesGoal            String?
  averageTicket        String?
  instagramPositioning String?
  logoUrl              String?
  bio                  String?
  contracts            Contract[]
  rateCards            RateCard[]
  recebidos            Recebido[]
  marketingAnalyses    MarketingAnalysis[]
}

model MarketingAnalysis {
  id           String   @id @default(uuid())
  companyId    String
  // "A1" | "A2" | "A3" | "A4" | "A5" | "O1" | "O2" | "O3" | "O4"
  analysisType String
  inputs       String // JSON stringified com os campos do formulário preenchido
  output       String // Relatório em Markdown gerado pela IA
  // Plano da empresa no momento da execução: "FREE" | "PRO" | "MASTER" | "ENTERPRISE"
  planTier     String
  createdAt    DateTime @default(now())

  company CompanyProfile @relation(fields: [companyId], references: [id])

  @@index([companyId, createdAt])
}

model SocialPlatform {
  id             String    @id @default(uuid())
  influencerId   String
  platformName   String // "INSTAGRAM" | "TIKTOK" | "YOUTUBE"
  platformId     String
  username       String?
  profilePicture String?
  followersCount Int       @default(0)
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@unique([influencerId, platformName])
}

model MetricSnapshot {
  id              String   @id @default(uuid())
  influencerId    String
  provider        String
  followers       Int
  engagementRate  Float
  reachLast30Days Int
  avgViews        Int
  capturedAt      DateTime @default(now())
  integrityHash   String

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@index([influencerId, capturedAt])
}

model Contract {
  id             String  @id @default(uuid())
  companyId      String
  influencerId   String
  title          String
  briefing       String? // Briefing enviado pela marca
  aiScript       String? // Roteiro/Estratégia sugerida pela IA
  budget         Float
  platformFee    Float?
  netAmount      Float?
  successFeeRate Float   @default(0.15)
  escrowStatus   String  @default("DRAFT") // "DRAFT" | "PENDING_PAYMENT" | ...
  externalTxId   String?
  releaseTxId    String? @unique
  idempotencyKey String? @unique

  company      CompanyProfile    @relation(fields: [companyId], references: [id])
  influencer   InfluencerProfile @relation(fields: [influencerId], references: [id])
  deliverables Deliverable[]
  createdAt    DateTime          @default(now())
}

model Deliverable {
  id         String   @id @default(uuid())
  contractId String
  type       String
  deadline   DateTime
  status     String   @default("PENDING")
  proofUrl   String?

  contract Contract @relation(fields: [contractId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  type      String
  isRead    Boolean  @default(false)
  metadata  String? // SQLite não suporta Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Task {
  id                    String    @id @default(uuid())
  influencerId          String
  title                 String
  description           String?
  scheduledDate         DateTime?
  isDone                Boolean   @default(false)
  fromAI                Boolean   @default(false)
  proofUrl              String?
  performanceMultiplier Float?

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@index([influencerId, scheduledDate])
}

model RateCard {
  id           String  @id @default(uuid())
  influencerId String?
  companyId    String?
  serviceName  String // ex: "3x Stories", "Reels", "Post Fixo"
  price        Float
  currency     String  @default("BRL")
  description  String?

  influencer InfluencerProfile? @relation(fields: [influencerId], references: [id])
  company    CompanyProfile?    @relation(fields: [companyId], references: [id])
}

model AdminStrategy {
  id            String   @id @default(uuid())
  strategyTitle String
  content       String // Estratégia gerada pela IA para o Alexsandro
  targetMetric  String // ex: "CAC", "Churn", "User Growth"
  generatedAt   DateTime @default(now())
}

model AIAnalysis {
  id              String   @id @default(uuid())
  influencerId    String
  analysisText    String
  recommendations String // SQLite não suporta String[], usaremos String (JSON ou separada por vírgula)
  generatedAt     DateTime @default(now())

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@index([influencerId, generatedAt])
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  message   String
  status    String   @default("OPEN") // "OPEN" | "IN_PROGRESS" | "CLOSED"
  category  String // "BUG" | "SUPPORT" | "FEATURE"
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())
}

model Recebido {
  id              String    @id @default(uuid())
  companyId       String
  influencerId    String
  title           String // ex: "Kit Maquiagem Verão"
  description     String? // ex: "Envio de batons e bases da coleção nova"
  status          String    @default("PENDING") // "PENDING" | "SHIPPED" | "DELIVERED" | "RECEIVED" | "REJECTED"
  trackingCode    String? // Código de rastreio dos Correios/transportadora
  shippingCarrier String? // Correios, DHL, Loggi, etc.
  sentAt          DateTime?
  receivedAt      DateTime?

  company    CompanyProfile    @relation(fields: [companyId], references: [id])
  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

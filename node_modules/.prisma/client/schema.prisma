generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  INFLUENCER
  COMPANY
  ADMIN
}

enum ContractStatus {
  DRAFT
  PENDING_PAYMENT
  IN_PROGRESS
  UNDER_REVIEW
  COMPLETED
  DISPUTE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())

  influencer    InfluencerProfile?
  company       CompanyProfile?
  notifications Notification[]
}

model InfluencerProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id])
  handle          String  @unique
  verifiedMetrics Boolean @default(false)

  platforms      SocialPlatform[]
  tasks          Task[]
  metricsHistory MetricSnapshot[]
  contracts      Contract[]
}

model CompanyProfile {
  id          String     @id @default(uuid())
  userId      String     @unique
  user        User       @relation(fields: [userId], references: [id])
  companyName String
  taxId       String     @unique
  contracts   Contract[]
}

model SocialPlatform {
  id           String    @id @default(uuid())
  influencerId String
  platformName String
  platformId   String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@unique([influencerId, platformName])
}

model MetricSnapshot {
  id              String   @id @default(uuid())
  influencerId    String
  provider        String
  followers       Int
  engagementRate  Float
  reachLast30Days Int
  avgViews        Int
  capturedAt      DateTime @default(now())
  integrityHash   String

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@index([influencerId, capturedAt])
}

model Contract {
  id           String         @id @default(uuid())
  companyId    String
  influencerId String
  title        String
  budget       Decimal        @db.Decimal(12, 2)
  escrowStatus ContractStatus @default(DRAFT)
  externalTxId String?

  company      CompanyProfile    @relation(fields: [companyId], references: [id])
  influencer   InfluencerProfile @relation(fields: [influencerId], references: [id])
  deliverables Deliverable[]
  createdAt    DateTime          @default(now())
}

model Deliverable {
  id         String   @id @default(uuid())
  contractId String
  type       String
  deadline   DateTime
  status     String   @default("PENDING")
  proofUrl   String?

  contract Contract @relation(fields: [contractId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  type      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Task {
  id            String    @id @default(uuid())
  influencerId  String
  title         String
  scheduledDate DateTime?
  isDone        Boolean   @default(false)

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@index([influencerId, scheduledDate])
}

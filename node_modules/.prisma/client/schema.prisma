generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Nota: SQLite não suporta Enums. Usaremos String com validação em nível de aplicação.
// As roles serão: "INFLUENCER", "COMPANY", "ADMIN"
// Os status serão: "DRAFT", "PENDING_PAYMENT", "IN_PROGRESS", "UNDER_REVIEW", "COMPLETED", "DISPUTE"

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  role             String // "INFLUENCER" | "COMPANY" | "ADMIN"
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String? // AES-256-GCM encrypted
  createdAt        DateTime @default(now())

  influencer    InfluencerProfile?
  company       CompanyProfile?
  notifications Notification[]
}

model InfluencerProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id])
  handle          String  @unique
  profileImageUrl String?
  verifiedMetrics Boolean @default(false)
  niche           String?
  influScore      Int     @default(0)
  scoreClass      String  @default("BRONZE")

  // Gamificação: Missões Diárias
  dailyMission      String?
  missionCompleted  Boolean   @default(false)
  lastMissionUpdate DateTime?
  lastLoginAt       DateTime  @default(now())

  // Hiper-Localismo
  city  String?
  state String?
  bio   String?

  insights String? // SQLite não suporta Json, usaremos String (JSON stringified)
  topPosts String? // SQLite não suporta Json, usaremos String (JSON stringified)

  platforms      SocialPlatform[]
  tasks          Task[]
  metricsHistory MetricSnapshot[]
  contracts      Contract[]
  aiAnalyses     AIAnalysis[]
  trendVault     TrendReference[]
}

model TrendReference {
  id           String   @id @default(uuid())
  influencerId String
  title        String
  videoUrl     String
  thumbnail    String?
  niche        String
  createdAt    DateTime @default(now())
  expiresAt    DateTime // Data de criação + 20 dias

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])
}

model CompanyProfile {
  id             String     @id @default(uuid())
  userId         String     @unique
  user           User       @relation(fields: [userId], references: [id])
  companyName    String
  taxId          String     @unique
  city           String?
  state          String?
  segment        String?
  employeeCount  String?
  campaignBudget String?
  contracts      Contract[]
}

model SocialPlatform {
  id           String    @id @default(uuid())
  influencerId String
  platformName String
  platformId   String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@unique([influencerId, platformName])
}

model MetricSnapshot {
  id              String   @id @default(uuid())
  influencerId    String
  provider        String
  followers       Int
  engagementRate  Float
  reachLast30Days Int
  avgViews        Int
  capturedAt      DateTime @default(now())
  integrityHash   String

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@index([influencerId, capturedAt])
}

model Contract {
  id             String  @id @default(uuid())
  companyId      String
  influencerId   String
  title          String
  budget         Float
  platformFee    Float?
  netAmount      Float?
  escrowStatus   String  @default("DRAFT") // "DRAFT" | "PENDING_PAYMENT" | ...
  externalTxId   String?
  releaseTxId    String? @unique
  idempotencyKey String? @unique

  company      CompanyProfile    @relation(fields: [companyId], references: [id])
  influencer   InfluencerProfile @relation(fields: [influencerId], references: [id])
  deliverables Deliverable[]
  createdAt    DateTime          @default(now())
}

model Deliverable {
  id         String   @id @default(uuid())
  contractId String
  type       String
  deadline   DateTime
  status     String   @default("PENDING")
  proofUrl   String?

  contract Contract @relation(fields: [contractId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  type      String
  isRead    Boolean  @default(false)
  metadata  String? // SQLite não suporta Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Task {
  id                    String    @id @default(uuid())
  influencerId          String
  title                 String
  description           String?
  scheduledDate         DateTime?
  isDone                Boolean   @default(false)
  fromAI                Boolean   @default(false)
  proofUrl              String?
  performanceMultiplier Float?

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@index([influencerId, scheduledDate])
}

model AIAnalysis {
  id              String   @id @default(uuid())
  influencerId    String
  analysisText    String
  recommendations String // SQLite não suporta String[], usaremos String (JSON ou separada por vírgula)
  generatedAt     DateTime @default(now())

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id])

  @@index([influencerId, generatedAt])
}
